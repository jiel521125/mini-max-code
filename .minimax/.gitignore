# ----- OS -----
.DS_Store
Thumbs.db
desktop.ini

# ----- 编辑器 -----
.vscode/
.idea/
*.swp
*.swo
*~

# ----- 临时文件 -----
*.tmp
*.log
*.bak
*.old

# ----- 导出包（项目本身的 zip 应被提交，但用户本地生成的临时 zip 不提交）-----
/*.zip
!/scripts/*.zip

# ----- 备份 -----
*.bak/
*.backup/
.backup/

# ----- Python 缓存（如果未来加 Python 工具）-----
__pycache__/
*.pyc

# ----- Node（如果未来加 Node 工具）-----
node_modules/

# ----- 敏感信息（绝对不能 commit）-----
.env
.env.local
*.key
*.pem
secrets/

# ----- 报告输出（运行时生成）-----
reports/
*.report.md
