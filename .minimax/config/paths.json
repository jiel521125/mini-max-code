{
  "_comment": "路径抽象层。所有相对路径都基于 .minimax/ 根目录。整个 .minimax/ 目录可独立迁移到任何项目。",
  "workspace_root": ".",
  "agents_dir": "./agents",
  "workflows_dir": "./workflows",
  "rules_dir": "./rules",
  "config_dir": "./config",
  "scripts_dir": "./scripts",
  "hooks_dir": "./hooks",
  "memory_dir": "./memory",
  "registry_file": "./agents/registry.json",
  "workflows_index": "./workflows/INDEX.md",
  "decisions_log": "./rules/workflow-decisions.md",
  "intent_router": "./workflows/_intent-router.md",
  "workflow_template": "./workflows/_template.md",
  "agents_schema": "./agents/_schema.md",
  "agents_readme": "./agents/README.md",
  "workflows_readme": "./workflows/README.md",
  "platform_config": "./config/platform.json",
  "project_metadata": "./project.json",
  "project_readme": "./README.md",
  "gitignore": "./.gitignore",
  "memory_schema": "./memory/_schema.md",
  "memory_readme": "./memory/_README.md",
  "memory_compress": "./memory/_compress.md",
  "memory_wakeup_protocol": "./memory/_wakeup-protocol.md",
  "memory_archive_readme": "./memory/_archive/README.md",
  "mavis_paths": {
    "_comment": "mavis 框架的全局路径，与项目路径不同",
    "agent_config_dir": "~/.mavis/agents/mavis",
    "memory_file": "~/.mavis/agents/mavis/memory/MEMORY.md",
    "hooks_dir": "~/.mavis/agents/mavis/hooks"
  },
  "required_files_globs": [
    "./README.md",
    "./project.json",
    "./agents/README.md",
    "./agents/_schema.md",
    "./agents/registry.json",
    "./workflows/README.md",
    "./workflows/_intent-router.md",
    "./workflows/_template.md",
    "./workflows/INDEX.md",
    "./rules/workflow-decisions.md",
    "./config/paths.json",
    "./config/platform.json",
    "./scripts/install.sh",
    "./hooks/project-bootstrap-check.md",
    "./memory/_schema.md",
    "./memory/_README.md",
    "./memory/_compress.md",
    "./memory/_wakeup-protocol.md"
  ]
}